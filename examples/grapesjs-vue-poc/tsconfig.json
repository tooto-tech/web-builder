{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "sourceMap": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@toototech/webbuilder/core": ["../../packages/webbuilder/src/core/index.ts"],
      "@toototech/webbuilder": ["../../packages/webbuilder/src/index.ts"],
      "@toototech/webbuilder-plugins/global-settings": ["../../packages/webbuilder-plugins/src/global-settings/index.ts"],
      "@/components/WebBuilder/utils/globalSettingsPrimitives": ["./src/vendor/utils/globalSettingsPrimitives.ts"],
      "@/components/WebBuilder/utils/globalSettingsHostDeps": ["./src/vendor/utils/globalSettingsHostDeps.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.vue", "vite.config.ts"]
}
