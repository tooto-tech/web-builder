{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "sourceMap": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@toototech/webbuilder": ["../../packages/webbuilder/src/index.ts"],
      "@toototech/webbuilder/core": ["../../packages/webbuilder/src/core/index.ts"],
      "@toototech/webbuilder-plugins": ["../../packages/webbuilder-plugins/src/index.ts"],
      "@toototech/webbuilder-plugins/basic": ["../../packages/webbuilder-plugins/src/components-basic/index.ts"],
      "@toototech/webbuilder-plugins/cms": ["../../packages/webbuilder-plugins/src/components-cms/index.ts"],
      "@toototech/webbuilder-plugins/global-settings": ["../../packages/webbuilder-plugins/src/global-settings/index.ts"],
      "@toototech/webbuilder-plugins/i18n": ["../../packages/webbuilder-plugins/src/localization/index.ts"],
      "@toototech/webbuilder-plugins/layout-template": ["../../packages/webbuilder-plugins/src/layout-templates/index.ts"],
      "@toototech/webbuilder-plugins/publisher": ["../../packages/webbuilder-plugins/src/publishing/index.ts"],
      "@toototech/webbuilder-plugins/vue": ["../../packages/webbuilder-plugins/src/vue-components.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.vue", "vite.config.ts"]
}
