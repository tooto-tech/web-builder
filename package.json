{
  "name": "@toototech/webbuilder-packages",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.1",
  "scripts": {
    "build": "pnpm --filter @toototech/webbuilder build && pnpm --filter @toototech/webbuilder-plugins build",
    "guard": "node scripts/webbuilder-packages-guard.mjs",
    "test": "pnpm run build && vitest run --config vitest.config.ts",
    "pack:dry-run": "pnpm run guard && pnpm run build && pnpm --filter @toototech/webbuilder --filter @toototech/webbuilder-plugins exec npm pack --dry-run --json"
  },
  "devDependencies": {
    "@iconify/iconify": "^3.1.1",
    "@iconify/json": "^2.2.187",
    "@iconify/vue": "^5.0.0",
    "@monaco-editor/loader": "^1.7.0",
    "@types/node": "^20.11.21",
    "@vitejs/plugin-vue": "5.0.4",
    "autoprefixer": "^10.4.17",
    "element-plus": "2.11.1",
    "grapesjs": "0.23.1",
    "monaco-editor": "^0.55.1",
    "postcss": "^8.4.35",
    "swiper": "^12.1.0",
    "tailwindcss": "^3.4.19",
    "typescript": "5.3.3",
    "vite": "5.1.4",
    "vitest": "4.0.18",
    "vue": "3.5.12",
    "vue-tsc": "^1.8.27"
  },
  "pnpm": {
    "overrides": {
      "grapesjs": "0.23.1"
    }
  }
}
