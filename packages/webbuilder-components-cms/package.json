{
  "name": "@toototech/webbuilder-components-cms",
  "version": "0.1.1",
  "type": "module",
  "private": false,
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "corepack pnpm@10.28.1 build"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.js"
    },
    "./publisher": {
      "types": "./dist/publisher.d.ts",
      "import": "./dist/publisher.js"
    }
  },
  "peerDependencies": {
    "@toototech/webbuilder-components-basic": "^0.1.0",
    "@toototech/webbuilder-core": "^0.1.0",
    "@toototech/webbuilder-layout-template": "^0.1.0",
    "grapesjs": "^0.23.1"
  },
  "devDependencies": {
    "@toototech/webbuilder-components-basic": "^0.1.0",
    "@toototech/webbuilder-core": "^0.1.0",
    "@toototech/webbuilder-layout-template": "^0.1.0"
  },
  "license": "MIT",
  "homepage": "https://www.npmjs.com/package/@toototech/webbuilder-components-cms",
  "publishConfig": {
    "access": "public"
  }
