{
  "name": "@toototech/webbuilder-plugins",
  "version": "0.2.0-alpha.2",
  "type": "module",
  "private": false,
  "sideEffects": [
    "*.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vite build --config vite.config.ts && vue-tsc -p tsconfig.build.json --declaration --emitDeclarationOnly",
    "prepack": "corepack pnpm@10.28.1 build"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./basic": {
      "types": "./dist/components-basic/index.d.ts",
      "import": "./dist/basic.js"
    },
    "./cms": {
      "types": "./dist/components-cms/index.d.ts",
      "import": "./dist/cms.js"
    },
    "./i18n": {
      "types": "./dist/localization/index.d.ts",
      "import": "./dist/i18n.js"
    },
    "./global-settings": {
      "types": "./dist/global-settings/index.d.ts",
      "import": "./dist/global-settings.js"
    },
    "./layout-template": {
      "types": "./dist/layout-templates/index.d.ts",
      "import": "./dist/layout-template.js"
    },
    "./publisher": {
      "types": "./dist/publishing/index.d.ts",
      "import": "./dist/publisher.js"
    },
    "./vue": {
      "types": "./dist/vue-components.d.ts",
      "import": "./dist/vue.js"
    },
    "./style.css": "./dist/style.css"
  },
  "typesVersions": {
    "*": {
      "basic": [
        "dist/components-basic/index.d.ts"
      ],
      "cms": [
        "dist/components-cms/index.d.ts"
      ],
      "i18n": [
        "dist/localization/index.d.ts"
      ],
      "global-settings": [
        "dist/global-settings/index.d.ts"
      ],
      "layout-template": [
        "dist/layout-templates/index.d.ts"
      ],
      "publisher": [
        "dist/publishing/index.d.ts"
      ],
      "vue": [
        "dist/vue-components.d.ts"
      ],
      "style.css": [
        "dist/style.css"
      ],
      "*": [
        "dist/index.d.ts"
      ]
    }
  },
  "dependencies": {
    "@iconify/iconify": "^3.1.1",
    "@iconify/json": "^2.2.187",
    "@iconify/vue": "^5.0.0",
    "element-plus": "^2.11.0",
    "grapesjs": "^0.23.1",
    "swiper": "^12.1.0"
  },
  "peerDependencies": {
    "@toototech/webbuilder": "^0.2.0-alpha.2",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@toototech/webbuilder": "workspace:*",
    "@vitejs/plugin-vue": "5.0.4",
    "typescript": "5.3.3",
    "vite": "5.1.4",
    "vue-tsc": "^1.8.27"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tooto-tech/web-builder",
    "directory": "packages/webbuilder-plugins"
  },
  "homepage": "https://www.npmjs.com/package/@toototech/webbuilder-plugins",
  "publishConfig": {
    "access": "public"
  }
}
