{
  "name": "@toototech/webbuilder",
  "version": "0.2.1",
  "type": "module",
  "private": false,
  "sideEffects": [
    "*.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vite build --config vite.config.ts && vue-tsc -p tsconfig.build.json --declaration --emitDeclarationOnly",
    "prepack": "corepack pnpm@10.28.1 build"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core.js"
    },
    "./style.css": "./dist/style.css"
  },
  "typesVersions": {
    "*": {
      "core": [
        "dist/core/index.d.ts"
      ],
      "style.css": [
        "dist/style.css"
      ],
      "*": [
        "dist/index.d.ts"
      ]
    }
  },
  "dependencies": {
    "@iconify/vue": "^5.0.0",
    "@tootix/grapesjs-vue": "0.0.2",
    "grapesjs": "^0.23.1",
    "naive-ui": "^2.44.1"
  },
  "peerDependencies": {
    "@monaco-editor/loader": "^1.7.0",
    "monaco-editor": "^0.55.0",
    "vue": "^3.5.0"
  },
  "peerDependenciesMeta": {
    "@monaco-editor/loader": {
      "optional": true
    },
    "monaco-editor": {
      "optional": true
    }
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "5.0.4",
    "typescript": "5.3.3",
    "vite": "5.1.4",
    "vue-tsc": "^1.8.27"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tooto-tech/web-builder",
    "directory": "packages/webbuilder"
  },
  "homepage": "https://www.npmjs.com/package/@toototech/webbuilder",
  "publishConfig": {
    "access": "public"
  }
}
